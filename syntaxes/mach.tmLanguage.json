{
    "scopeName": "source.mach",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#characters"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#types"
        },
        {
            "include": "#compiletime"
        },
        {
            "include": "#asm"
        },
        {
            "include": "#use-statements"
        },
        {
            "include": "#declarations"
        },
        {
            "include": "#calls"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#identifiers"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.number-sign.mach",
                    "match": "#.*$"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.mach",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "include": "#string-escapes"
                        }
                    ]
                }
            ]
        },
        "characters": {
            "patterns": [
                {
                    "name": "string.quoted.single.mach",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "include": "#string-escapes"
                        }
                    ]
                }
            ]
        },
        "string-escapes": {
            "patterns": [
                {
                    "name": "constant.character.escape.mach",
                    "match": "\\\\x[0-9A-Fa-f]{2}"
                },
                {
                    "name": "constant.character.escape.mach",
                    "match": "\\\\['\"\\\\tnr0]"
                },
                {
                    "name": "invalid.illegal.unrecognized-escape.mach",
                    "match": "\\\\."
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.float.mach",
                    "match": "\\b\\d[\\d_]*(?:\\.\\d[\\d_]*(?:[eE][+-]?\\d[\\d_]*)?|[eE][+-]?\\d[\\d_]*)(?:f\\d*)?\\b"
                },
                {
                    "name": "constant.numeric.hex.mach",
                    "match": "\\b0[xX][0-9A-Fa-f_]+(?:[ui]\\d*)?\\b"
                },
                {
                    "name": "constant.numeric.binary.mach",
                    "match": "\\b0[bB][01_]+(?:[ui]\\d*)?\\b"
                },
                {
                    "name": "constant.numeric.octal.mach",
                    "match": "\\b0[oO][0-7_]+(?:[ui]\\d*)?\\b"
                },
                {
                    "name": "constant.numeric.integer.mach",
                    "match": "\\b\\d[\\d_]*(?:[ui]\\d*)?\\b"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "storage.modifier.mach",
                    "match": "\\b(?:pub|ext)\\b"
                },
                {
                    "name": "keyword.declaration.mach",
                    "match": "\\b(?:def|val|var|fun|rec|uni|use|fwd|test)\\b"
                },
                {
                    "name": "keyword.control.mach",
                    "match": "\\b(?:if|or|for|brk|cnt|ret|fin|asm)\\b"
                },
                {
                    "name": "constant.language.mach",
                    "match": "\\bnil\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.primitive.mach",
                    "match": "\\b(?:u8|u16|u32|u64|i8|i16|i32|i64|f32|f64|ptr)\\b"
                },
                {
                    "include": "#cast"
                },
                {
                    "include": "#type-annotation"
                }
            ]
        },
        "cast": {
            "patterns": [
                {
                    "match": "(::|:~)\\s*((?:\\*)*)\\s*(?:(u8|u16|u32|u64|i8|i16|i32|i64|f32|f64|ptr)\\b|([A-Za-z_][A-Za-z0-9_]*))",
                    "captures": {
                        "1": {
                            "name": "keyword.operator.cast.mach"
                        },
                        "2": {
                            "name": "keyword.operator.type.mach"
                        },
                        "3": {
                            "name": "storage.type.primitive.mach"
                        },
                        "4": {
                            "name": "support.type.alias.mach"
                        }
                    }
                }
            ]
        },
        "type-annotation": {
            "patterns": [
                {
                    "name": "meta.type.annotation.mach",
                    "begin": "(:)\\s*((?:\\*|\\[(?:\\d+|_)?\\])\\s*)*",
                    "end": "(?=[,;=)}\\]]|\\s*(?:=|;|\\{|\\)))",
                    "beginCaptures": {
                        "1": {
                            "name": "punctuation.separator.type.mach"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#type-expression"
                        }
                    ]
                }
            ]
        },
        "type-expression": {
            "patterns": [
                {
                    "name": "storage.type.primitive.mach",
                    "match": "\\b(?:u8|u16|u32|u64|i8|i16|i32|i64|f32|f64|ptr)\\b"
                },
                {
                    "name": "keyword.declaration.mach",
                    "match": "\\b(?:fun|rec|uni)\\b"
                },
                {
                    "name": "meta.type.generic.mach",
                    "begin": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(\\[)",
                    "end": "(\\])",
                    "beginCaptures": {
                        "1": {
                            "name": "support.type.alias.mach"
                        },
                        "2": {
                            "name": "punctuation.definition.typeparameters.begin.mach"
                        }
                    },
                    "endCaptures": {
                        "1": {
                            "name": "punctuation.definition.typeparameters.end.mach"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#type-expression"
                        }
                    ]
                },
                {
                    "name": "support.type.alias.mach",
                    "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
                },
                {
                    "name": "keyword.operator.type.mach",
                    "match": "\\*|\\[(?:\\d+|_)?\\]"
                }
            ]
        },
        "compiletime": {
            "patterns": [
                {
                    "name": "keyword.control.compiletime.mach",
                    "match": "\\$(?:if|or)\\b"
                },
                {
                    "name": "support.function.compiletime.mach",
                    "match": "\\$[a-z_][a-z0-9_]*(?=\\s*\\()"
                },
                {
                    "name": "support.constant.compiletime.mach",
                    "match": "\\$[A-Z_][A-Z0-9_]*\\b"
                },
                {
                    "match": "(\\$[a-z_][a-z0-9_]*)(\\.)",
                    "captures": {
                        "1": {
                            "name": "variable.other.compiletime.mach"
                        },
                        "2": {
                            "name": "punctuation.accessor.mach"
                        }
                    }
                },
                {
                    "name": "variable.other.compiletime.mach",
                    "match": "\\$[a-z_][a-z0-9_]*\\b"
                }
            ]
        },
        "asm": {
            "patterns": [
                {
                    "begin": "\\b(asm)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(\\{)",
                    "end": "(\\})",
                    "beginCaptures": {
                        "1": {
                            "name": "keyword.control.mach"
                        },
                        "2": {
                            "name": "entity.name.tag.isa.mach"
                        },
                        "3": {
                            "name": "punctuation.section.block.begin.mach"
                        }
                    },
                    "endCaptures": {
                        "1": {
                            "name": "punctuation.section.block.end.mach"
                        }
                    },
                    "contentName": "meta.embedded.asm.mach",
                    "patterns": [
                        {
                            "name": "comment.line.number-sign.mach",
                            "match": "#.*$"
                        },
                        {
                            "name": "variable.other.asm.substitution.mach",
                            "match": "\\{[A-Za-z_][A-Za-z0-9_]*\\}"
                        }
                    ]
                }
            ]
        },
        "use-statements": {
            "patterns": [
                {
                    "name": "meta.use.aliased.mach",
                    "match": "\\b(use|fwd)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(:)\\s*([A-Za-z_][A-Za-z0-9_.]*)",
                    "captures": {
                        "1": {
                            "name": "keyword.declaration.mach"
                        },
                        "2": {
                            "name": "entity.name.namespace.alias.mach"
                        },
                        "3": {
                            "name": "punctuation.separator.mach"
                        },
                        "4": {
                            "name": "entity.name.namespace.mach"
                        }
                    }
                },
                {
                    "name": "meta.use.simple.mach",
                    "match": "\\b(use|fwd)\\s+([A-Za-z_][A-Za-z0-9_.]*)",
                    "captures": {
                        "1": {
                            "name": "keyword.declaration.mach"
                        },
                        "2": {
                            "name": "entity.name.namespace.mach"
                        }
                    }
                }
            ]
        },
        "declarations": {
            "patterns": [
                {
                    "name": "meta.definition.method.mach",
                    "match": "\\b(?:(?:pub|ext)\\s+)*fun\\s+\\(\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*:\\s*[*]*([A-Za-z_][A-Za-z0-9_\\[\\]]*)\\s*\\)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(?:\\[(?:[^\\[\\]]|\\[[^\\[\\]]*\\])*\\])?\\s*\\(",
                    "captures": {
                        "1": {
                            "name": "variable.parameter.mach"
                        },
                        "2": {
                            "name": "entity.name.type.mach"
                        },
                        "3": {
                            "name": "entity.name.function.mach"
                        }
                    }
                },
                {
                    "name": "meta.definition.function.mach",
                    "match": "\\b(?:(?:pub|ext)\\s+)*fun\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(?:\\[(?:[^\\[\\]]|\\[[^\\[\\]]*\\])*\\])?\\s*\\(",
                    "captures": {
                        "1": {
                            "name": "entity.name.function.mach"
                        }
                    }
                },
                {
                    "name": "meta.declaration.type.mach",
                    "match": "\\b(?:(?:pub|ext)\\s+)*(?:rec|uni)\\s+([A-Za-z_][A-Za-z0-9_]*)(?:\\s*\\[(?:[^\\[\\]]|\\[[^\\[\\]]*\\])*\\])?",
                    "captures": {
                        "1": {
                            "name": "entity.name.type.mach"
                        }
                    }
                },
                {
                    "name": "meta.declaration.alias.mach",
                    "match": "\\b(?:(?:pub|ext)\\s+)*def\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
                    "captures": {
                        "1": {
                            "name": "entity.name.type.mach"
                        }
                    }
                },
                {
                    "name": "meta.declaration.binding.mach",
                    "match": "\\b(?:(?:pub|ext)\\s+)*(?:val|var)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
                    "captures": {
                        "1": {
                            "name": "variable.other.definition.mach"
                        }
                    }
                }
            ]
        },
        "calls": {
            "patterns": [
                {
                    "name": "meta.function.call.mach",
                    "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\b(?=\\s*(?:\\[(?:[^\\[\\]]|\\[[^\\[\\]]*\\])*\\])?\\s*\\()",
                    "captures": {
                        "1": {
                            "name": "entity.name.function.call.mach"
                        }
                    }
                },
                {
                    "name": "meta.function.call.mach",
                    "match": "(?<=\\.)([A-Za-z_][A-Za-z0-9_]*)\\b(?=\\s*(?:\\[(?:[^\\[\\]]|\\[[^\\[\\]]*\\])*\\])?\\s*\\()",
                    "captures": {
                        "1": {
                            "name": "entity.name.function.call.mach"
                        }
                    }
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.cast.mach",
                    "match": "::|:~"
                },
                {
                    "name": "keyword.operator.mach",
                    "match": "==|!=|<=|>=|<<|>>|&&|\\|\\||\\.\\.\\.|\\+|-|\\*|/|%|\\^|&|\\||=|<|>|!|~|@|\\?"
                }
            ]
        },
        "identifiers": {
            "patterns": [
                {
                    "name": "variable.other.mach",
                    "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
                }
            ]
        }
    }
}
